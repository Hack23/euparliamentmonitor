{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/**/*.ts"],
  "entryPointStrategy": "expand",
  "out": "builds/api",
  "name": "EU Parliament Monitor — API Documentation",
  "readme": "README.md",
  "tsconfig": "tsconfig.json",
  "plugin": [],
  "exclude": [
    "**/node_modules/**",
    "**/*.test.*",
    "**/*.spec.*"
  ],
  "blockTags": [
    "@author",
    "@callback",
    "@category",
    "@default",
    "@defaultValue",
    "@deprecated",
    "@description",
    "@enum",
    "@example",
    "@file",
    "@gdpr",
    "@hidden",
    "@intelligence",
    "@internal",
    "@license",
    "@link",
    "@module",
    "@osint",
    "@override",
    "@param",
    "@returns",
    "@remarks",
    "@risk",
    "@see",
    "@security",
    "@since",
    "@throws",
    "@type",
    "@typedef",
    "@typeParam",
    "@version",
    "@parliament",
    "@political",
    "@compliance",
    "@pipeline",
    "@dashboard",
    "@visualization",
    "@datasource",
    "@stakeholder",
    "@performance"
  ],
  "excludePrivate": false,
  "excludeProtected": false,
  "excludeInternal": false,
  "excludeExternals": true,
  "excludeNotDocumented": false,
  "excludeReferences": false,
  "includeVersion": true,
  "includeHierarchySummary": true,
  "categorizeByGroup": true,
  "groupReferencesByType": true,
  "categoryOrder": [
    "Types & Models",
    "MCP Integration",
    "Intelligence & Data",
    "Content Generation",
    "Pipeline Stages",
    "News Strategies",
    "Business & Configuration",
    "Templates & Presentation",
    "Constants & Configuration",
    "Utilities",
    "*"
  ],
  "groupOrder": [
    "Functions",
    "Classes",
    "Interfaces",
    "Type Aliases",
    "Enumerations",
    "Variables",
    "Namespaces",
    "*"
  ],
  "kindSortOrder": [
    "Module",
    "Namespace",
    "Class",
    "Interface",
    "TypeAlias",
    "Enum",
    "Function",
    "Variable",
    "EnumMember",
    "Constructor",
    "Property",
    "Accessor",
    "Method",
    "Parameter",
    "TypeParameter",
    "TypeLiteral",
    "CallSignature",
    "ConstructorSignature",
    "IndexSignature",
    "GetSignature",
    "SetSignature"
  ],
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "navigationLinks": {
    "🏠 Home": "https://euparliamentmonitor.com",
    "📦 GitHub": "https://github.com/Hack23/euparliamentmonitor",
    "🛡️ ISMS": "https://github.com/Hack23/ISMS-PUBLIC",
    "🇪🇺 EP MCP Server": "https://github.com/Hack23/European-Parliament-MCP-Server"
  },
  "sidebarLinks": {
    "🏛️ Architecture": "https://github.com/Hack23/euparliamentmonitor/blob/main/ARCHITECTURE.md",
    "🔒 Security Architecture": "https://github.com/Hack23/euparliamentmonitor/blob/main/SECURITY_ARCHITECTURE.md",
    "🛡️ Threat Model": "https://github.com/Hack23/euparliamentmonitor/blob/main/THREAT_MODEL.md",
    "📊 Data Model": "https://github.com/Hack23/euparliamentmonitor/blob/main/DATA_MODEL.md",
    "🔄 Flowchart": "https://github.com/Hack23/euparliamentmonitor/blob/main/FLOWCHART.md",
    "📈 State Diagram": "https://github.com/Hack23/euparliamentmonitor/blob/main/STATEDIAGRAM.md",
    "🧠 Mindmap": "https://github.com/Hack23/euparliamentmonitor/blob/main/MINDMAP.md",
    "💼 SWOT Analysis": "https://github.com/Hack23/euparliamentmonitor/blob/main/SWOT.md",
    "📜 CRA Assessment": "https://github.com/Hack23/euparliamentmonitor/blob/main/CRA-ASSESSMENT.md",
    "🚀 Future Architecture": "https://github.com/Hack23/euparliamentmonitor/blob/main/FUTURE_ARCHITECTURE.md",
    "🔮 Future Security": "https://github.com/Hack23/euparliamentmonitor/blob/main/FUTURE_SECURITY_ARCHITECTURE.md",
    "📋 Secure Dev Policy": "https://github.com/Hack23/ISMS-PUBLIC/blob/main/Secure_Development_Policy.md"
  },
  "sort": ["kind", "source-order", "alphabetical"],
  "visibilityFilters": {
    "protected": true,
    "private": true,
    "inherited": true,
    "@alpha": false,
    "@beta": false
  },
  "searchInComments": true,
  "searchInDocuments": true,
  "cleanOutputDir": true,
  "githubPages": true,
  "hideGenerator": false,
  "markdownLinkExternal": true,
  "suppressCommentWarningsInDeclarationFiles": true,
  "highlightLanguages": [
    "bash",
    "console",
    "css",
    "html",
    "javascript",
    "json",
    "jsonc",
    "mermaid",
    "sh",
    "shell",
    "sql",
    "tsx",
    "typescript",
    "xml",
    "yaml"
  ],
  "favicon": "favicon.ico",
  "hostedBaseUrl": "https://euparliamentmonitor.com/docs/api/",
  "projectDocuments": [
    "ARCHITECTURE.md",
    "SECURITY_ARCHITECTURE.md",
    "THREAT_MODEL.md",
    "DATA_MODEL.md",
    "FLOWCHART.md",
    "STATEDIAGRAM.md",
    "MINDMAP.md",
    "SWOT.md",
    "CRA-ASSESSMENT.md"
  ]
}
